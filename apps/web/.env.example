# Turso Database Configuration
# Get these values from: https://turso.tech
# 1. Create account: turso auth signup
# 2. Create database: turso db create gymmer
# 3. Get URL: turso db show gymmer --url
# 4. Get token: turso db tokens create gymmer

TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# NextAuth / OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAILS=

# Claude / Anthropic LLM calls
# Create a key in Anthropic Console and add it in Vercel project env vars.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional overrides:
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_VERSION=2023-06-01

# App token exchange (mobile)
APP_JWT_SECRET=change-me-to-a-long-random-string

# Nightly cardio activity reminders (Web Push)
# Generate VAPID keys with: bunx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
# Also supported for compatibility:
# WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
# WEB_PUSH_PRIVATE_KEY=your-vapid-private-key
# WEB_PUSH_SUBJECT=mailto:you@example.com

# Used by the scheduled reminder endpoint.
CRON_SECRET=change-me-to-a-long-random-string
CRON_JOB_ORG_API_KEY=your-cron-job-org-api-key
